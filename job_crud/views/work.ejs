<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Work Experience</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
</head>
  <body><h1 style="text-align: center;">Work Experience</h1>
    <div class="col col-12 d-flex justify-content-end">
      <a href="/edit-work?id=<%= id %>" class="btn m-1 btn-primary">Edit</a>
    </div>
    <table class="table table-responsive table-bordered ">
      <tr>
        <th>Sr No.</th>
        <th>Company</th>
        <th>Designation</th>
        <th>From</th>
        <th>To</th>
        <th>Annual Package</th>
        <th>Reason to Leave</th>
        <th>Reference Contact Name</th>
        <th>Reference Contact Number</th>
        <th>Actions</th>
      </tr>
      <%work.forEach(item => {%>
        <tr>
            <td><%= item.id%></td>
            <td><%= item.company_name%></td>
            <td><%= item.designation%></td>
            <td><%= new Date(item.from_date).toLocaleDateString() %></td>
            <td><%= new Date(item.to_date).toLocaleDateString() %></td>
            <td><%= item.annual_package%></td>
            <td><%= item.reason_to_leave%></td>
            <td><%= item.ref_contact_name%></td>
            <td><%= item.ref_contact_number%></td>
            <td>
              <a href="/delete-experience?id=<%= item.id %>" class="btn btn-danger">Delete</a>
            </td>  
          </tr>
      <%})%>  
    </table>
    <a href="/" class="btn btn-primary">Home</a>
  </body>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</html>
