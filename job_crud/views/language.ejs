<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Language Skills</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    />
  </head>
  <body>
    <h1 style="text-align:center">Language Known</h1>
    <table class="table table-responsive">
      <tr>
        <!-- <th>ID</th> -->
        <th>Language</th>
        <th>Can Read</th>
        <th>Can Write</th>
        <th>Can Speak</th>
        <th>Actions</th>
      </tr>
      <%lanData.forEach(item => {%>
        <tr>
            <!-- <td><%= item.id%></td> -->
            <td><%= item.language_name%></td>
            <td><%= item.can_read == 1 ? "Yes" : "No"%></td>
            <td><%= item.can_write == 1 ? "Yes" : "No"%></td>
            <td><%= item.can_speak == 1 ? "Yes" : "No"%></td>
            <td><a href="/edit-language?id=<%=item.id%>" class="btn btn-primary">Edit</a> <a href="/delete-language?id=<%= item.id%>" class="btn btn-danger">Delete</a></td>
          </tr>
      <%})%>  
    </table>
    <a href="/" class="text-decoration-none btn btn-primary">Back</a>
  </body>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</html>
