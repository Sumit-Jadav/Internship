<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Education Details</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
</head>
<body>
    <h1 style="text-align:center">Education Details</h1>
    <div class="col col-12 d-flex justify-content-end ">
        <a href="/edit-education?id=<%= id %>" class="btn btn-warning me-3 mb-3">Edit</a>
    </div>
    <table class="table table-bordered table-responsive">
        <tr>
            <td>Sr No.</td>
            <td>Course</td>
            <td>University</td>
            <td>Passing Year</td>
            <td>Result</td>
            <td>Actions</td>
        </tr>
        <% education.forEach((edu,index) =>{%>
        <tr>
            <td><%= index + 1 %></td>
            <td><%= edu.course %></td>
            <td><%= edu.university %></td>
            <td><%= edu.passing_year %></td>
            <td><%= edu.result %></td>
            <td>
                
                <a href="/delete-education?id=<%= edu.id %>" class="btn btn-danger">Delete</a>
        </tr>
        <%}); %>
    </table>
    <a href="/" class="btn btn-primary">Home</a>
</body>
<script>




</script>
</html>