<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Job Application</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
  </head>
  <body
    class="w-100 h-100 bg-light d-flex flex-column align-items-center justify-content-center"
  >
    <div
      class="container w-100 p-2 d-flex align-items-center justify-content-center"
    >
      <h1>Job Application</h1>
      <a href="./insert" class="btn d-block btn-primary">Insert Data</a>
    </div>

    <table class="table table-responsive table-bordered">
      <tr>
        <th>Sr No.</th>
        <th>Name</th>
        <th>Phone</th>
        <th>Email</th>
        <th>Applied Designation</th>
        <th>Address</th>
        <th>City</th>
        <th>State</th>
        <th>Pincode</th>
        <th>Gender</th>
        <th>Relationship Status</th>
        <th>DOB</th>
        <th>Education Info</th>
        <th>Work Info</th>
        <th>Language</th>
        <th>Skills</th>
        <th>Reference</th>
        <th>Preference</th>
      </tr>
      <% data.forEach((item,index) => { %>
      <tr>
        <td><%= item.id%></td>
        <td><%= item.name %></td>
        <td><%= item.phone %></td>
        <td><%= item.email %></td>
        <td><%= item.designation %></td>
        <td><%= item.address %></td>
        <td><%= item.city %></td>
        <td><%= item.state %></td>
        <td><%= item.pincode %></td>
        <td><%= item.gender %></td>
        <td><%= item.status %></td>
        <td><%= item.dob %></td>
        <td><a class="btn btn-primary" href="/edu?id=<%= item.id%>">
            See  
        </a></td>
        <td><a class="btn btn-primary" href="/work?id=<%= item.id%>">
            See  
        </a></td>
        <td><a class="btn btn-primary" href="/lan?id=<%= item.id%>">
            See  
        </a></td>
        <td><a class="btn btn-primary" href="/skill?id=<%= item.id%>">
            See  
        </a></td>
        <td><a class="btn btn-primary" href="/ref?id=<%= item.id%>">
            See  
        </a></td>
        <td><a class="btn btn-primary" href="/pref?id=<%= item.id%>">
            See  
        </a></td>
      </tr>
    <%});%>
    </table>
  </body>
 <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" ></script>

</html>
