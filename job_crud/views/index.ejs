<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Job Application</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
  </head>
  <body
    class="w-100 h-100 bg-light d-flex flex-column align-items-center justify-content-center"
  >
    <div
      class="container p-2 d-flex flex-column align-items-center justify-content-center"
    >
      <h1>Job Application</h1>
      <a href="./insert" class="btn  btn-primary align-self-end">Insert Data</a>
    </div>
    <div class="table-responsive" style="width: 95%;"> 

      <table class="table table-responsive table-bordered" style="font-size: 0.8rem;">
        <tr>
          <th>Sr No.</th>
          <th>Name</th>
          <th>Phone</th>
          <th>Email</th>
          <th>Applied Designation</th>
          <th>Address</th>
          <th>City</th>
          <th>State</th>
          <th>Pincode</th>
          <th>Gender</th>
          <th>Relationship Status</th>
          <th>DOB</th>
          <th>Education Info</th>
          <th>Work Info</th>
          <th>Language</th>
          <th>Skills</th>
          <th>Reference</th>
          <th>Preference</th>
          <th>Actions</th>
        </tr>
        <% data.forEach((item,index) => { %>
        <tr>
          <td><%= item.id%></td>
          <td><%= item.first_name %><%= " "%><%= item.last_name %></td>
          <td><%= item.phone_number %></td>
          <td><%= item.email_address %></td>
          <td><%= item.applied_designation %></td>
          <td><%= item.first_line + " " %><%= item.second_line%></td>
          <td><%= item.applicant_city %></td>
          <td><%= item.applicant_state %></td>
          <td><%= item.applicant_pincode %></td>
          <td><%= item.gender %></td>
          <td><%= item.relationship_status %></td>
          <td><%= new Date(item.date_of_birth).toLocaleDateString() %></td>
          <td><a class="btn btn-primary" href="/edu?id=<%= item.id%>">
              See  
          </a></td>
          <td><a class="btn btn-primary" href="/work?id=<%= item.id%>">
              See  
          </a></td>
          <td><a class="btn btn-primary" href="/lan?id=<%= item.id%>">
              See  
          </a></td>
          <td><a class="btn btn-primary" href="/skill?id=<%= item.id%>">
              See  
          </a></td>
          <td><a class="btn btn-primary" href="/ref?id=<%= item.id%>">
              See  
          </a></td>
          <td><a class="btn btn-primary" href="/pref?id=<%= item.id%>">
              See  
          </a></td>
          <td>
            <a href="/edit-application?id=<%= item.id %>" class="btn btn-warning">Edit</a>
            <a href="/delete-application?id=<%= item.id %>" class="btn btn-danger">Delete</a>
          </td>
        </tr>
      <%});%>
      </table>
    </div>
    <div class="row">
      <div class="col col-12 d-flex justify-content-center">
        <%if(! (current_page == 1)){%>
        <a href="?page=<%=1%>" class="btn btn btn-warning m-1"><<</a>
        <%}%>
        <%if((current_page > 1 )){%>
        <a href="?page=<%= current_page - 1 %>" class="btn btn btn-warning m-1"><</a>
        <%}%>
        <%if(current_page < total_pages){%>
        <a href="?page=<%= parseInt(current_page) + 1  %>" class="btn btn btn-warning m-1">></a>
        <%}%>
        <a href="?page=<%= total_pages %>" class="btn btn btn-warning m-1">>></a>
      </div>
    </div>
  </body>
 <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" ></script>

<script>
  let modal = document.getElementById('applicant-modal');
  modal.addEventListener('show.bs.modal', function (event) {
    let button = event.relatedTarget;
    let id = button.getAttribute('data-bs-id');
    
  }); 
</script>


</html>
