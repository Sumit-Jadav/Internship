<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reference Details</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
</head>
<body>
    <h1 style="text-align:center">Reference By</h1>
    <table class="table table-bordered table-responsive">
        <tr>
            <td>Sr No.</td>
            <td>Reference Name</td>
            <td>Reference Contact</td>
            <td>Relation</td>
            <td>Actions</td>
        </tr>
        <% reference.forEach((ref,index) =>{%>
        <tr>
            <td><%= index + 1 %></td>
            <td><%= ref.reference_name %></td>
            <td><%= ref.reference_contact %></td>
            <td><%= ref.relation %></td>
            <td><a href="/edit-reference?id=<%= ref.id %>" class="btn btn-primary">Edit</a><a href="/delete-reference?id=<%= ref.id %>" class="btn btn-danger">Delete</a></td>
        </tr>
        <%}); %>
    </table>
    <a href="/" class="btn btn-primary">Home</a>
</body>
</html>
