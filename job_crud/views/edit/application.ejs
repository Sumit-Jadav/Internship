<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Application</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    />
     <!-- <script src="https://unpkg.com/just-validate@latest/dist/just-validate.production.min.js"></script> -->
  </head>
  <body>
    <h1 style="text-align: center">Edit Application</h1>
    <form action="/edit-application" method="POST" class="form container">
      <input type="hidden" name="id" value="<%= appData.applicant_id %>" />
      <div class="row">
        <div class="col-6">
            <div class="mb-3">
                <label for="first_name" class="form-label">First Name</label>
                <input
                type="text"
                class="form-control"
                id="first_name"
                name="first_name"
                value="<%= appData.first_name %>"
                />
            </div>
        </div>
        <div class="col-6">
            <div class="mb-3">
                <label for="last_name" class="form-label">Last Name</label>
                <input
                type="text"
                class="form-control"
                id="last_name"
                name="last_name"
                value="<%= appData.last_name %>"
                />
            </div>
      </div>
        <div class="mb-3 col-6">
            <label for="email_address" class="form-label">Email address</label>
            <input
            type="email"
            class="form-control"
            id="email_address"
            name="email_address"
            value="<%= appData.email_address %>"
            />
        </div>
        <div class="mb-3 col-6">
            <label for="phone_number" class="form-label">Phone Number</label>
            <input
            type="text"
            class="form-control"
            id="phone_number"
            name="phone_number"
            value="<%= appData.phone_number %>"
            />
        </div>
        <div class="mb-3 col-6">
            <label for="applied_designation" class="form-label">Applied Designation</label>
            <input
            type="text"
            class="form-control"
            id="applied_designation"
            name="applied_designation"
            value="<%= appData.applied_designation %>"
            />
        </div>
        <div class="mb-3 col-6">
            <label for="first_line" class="form-label">First Line of Address</label>
            <input
            type="text"
            class="form-control"
            id="first_line"
            name="first_line"
            value="<%= appData.first_line %>"
            />
        </div>
        <div class="mb-3 col-6">
            <label for="second_line" class="form-label">Second Line of Address</label>
            <input
            type="text"
            class="form-control"            id="second_line"
            name="second_line"
            value="<%= appData.second_line %>"
            />
        </div>
        <div class="mb-3 col-6">
            <label for="applicant_city" class="form-label">City</label>
            <input
            type="text"
            class="form-control"            id="applicant_city"
            name="applicant_city"
            value="<%= appData.applicant_city %>"
            />
        </div>
        <div class="mb-3 col-6">
            <label for="applicant_state" class="form-label">State</label>
            <select class="form-select" id="applicant_state" name="applicant_state">
                <option value="Gujarat" <%= appData.applicant_state === 'gujarat' ? 'selected' : '' %>>Gujarat</option>
                <option value="Delhi" <%= appData.applicant_state === 'Delhi' ? 'selected' : '' %>>Delhi</option>
                
            </select>
        </div>
        <div class="mb-3 col-6">  
            <label for="applicant_pincode" class="form-label">Pincode</label>
            <input
            type="text"
            class="form-control"            id="applicant_pincode"
            name="applicant_pincode"
            value="<%= appData.applicant_pincode %>"
            />
        </div>
        <div class="mb-3 col-6">
            <label for="gender" class="form-label"> Gender</label>
            <select class="form-select" id="gender" name="gender">
                <option value="male" <%= appData.gender === 'male' ? 'selected' : '' %>>Male</option>
                <option value="female" <%= appData.gender === 'female' ? 'selected' : '' %>>Female  </option>
            </select>
        </div>
        <div class="mb-3 col-6">
            <label for="status" class="form-label"> Status</label>
            <select class="form-select" id="status" name="status">
                <option value="single" <%= appData.status === 'single' ? 'selected' : '' %>>Single</option>
                <option value="married" <%= appData.status === 'married' ? 'selected' : '' %>>Married</option>
            </select>
        </div>
        <div class="mb3 col-12 d-flex justify-content-center">
            <div class="mb-3 col-6">
                <label for="dob" class="form-label"> Date of Birth</label>
                <input type="date" class="form-control" id="dob" name="dob" value="<%= new Date(formattedDate).toISOString().split('T')[0] %>"/>
            </div>
        </div>
        <div class="mb3 col-12 d-flex justify-content-center">
            <div class="mb3 col-6 d-flex justify-content-center">
                <input type="submit" value="Update" class="btn btn-primary">
                <a href="/" class="btn btn-primary ms-3">Back</a>
              </div>
        </div>
        </form>

  </body>
  <script>
    const validate = new window.JustValidate("#form");
    validate.addField("#first_name", [
      { rule: "required", errorMessage: "First Name is required" },
      {
        validator: (value) => /^[A-Za-z]+$/.test(value),
        errorMessage: "Only alphabets allowed",
      },
    ]);

    validate.addField("#email_address", [
      { rule: "required", errorMessage: "Email is required" },
      { rule: "email", errorMessage: "Email is not valid" },
    ]);

    validate.addField("#last_name", [
      { rule: "required", errorMessage: "Last Name is required" },
      {
        validator: (value) => /^[A-Za-z]+$/.test(value),
        errorMessage: "Only alphabets allowed",
      },
    ]);

    validate.addField("#applied_designation", [
      { rule: "required", errorMessage: "Designation is required" },
    ]);

    validate.addField("#first_line", [
      { rule: "required", errorMessage: "Address Line 1 required" },
    ]);

    validate.addField("#second_line", [
      { rule: "required", errorMessage: "Address Line 2 required" },
    ]);

    validate.addField("#applicant_city", [
      { rule: "required", errorMessage: "City required" },
    ]);

    validate.addField("#applicant_state", [
      { rule: "required", errorMessage: "State required" },
    ]);

    validate.addField("#applicant_pincode", [
      { rule: "required", errorMessage: "Pincode required" },
      {
        validator: (value) => /^[0-9]{6}$/.test(value),
        errorMessage: "Pincode must be 6 digits",
      },
    ]);

    validate.addField("#phone_number", [
      { rule: "required", errorMessage: "Phone number required" },
      {
        validator: (value) => /^[0-9]{10}$/.test(value),
        errorMessage: "Phone must be 10 digits",
      },
    ]);
  
    validate.addField("#dob", [
      { rule: "required", errorMessage: "Date of Birth required" },
      {
        validator: (value) => {
          const today = new Date();
          const dob = new Date(value);
            if(dob > today) {
                return false;
            }
        },
        errorMessage: "DOB cannot be in the future",
      },
    ]);
  
      validate.onSuccess((event) => {
        event.preventDefault();
        event.target.submit();
      });
  </script>
</html>
