<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Language Skills</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    />
  </head>
  <body>
    <h1 class="m-3 text-center">Edit Techonologies</h1>
    <form action="/edit-skill" method="post" id="form">
        <input type="hidden" name="id" value="<%=id%>">
        
        <table class="table table-responsive">
          <tr>
            <!-- <th>ID</th> -->
            <th>Techonology</th>
            <th>Beginner</th>
            <th>Intermediate</th>
            <th>Expert</th>
            
          </tr>
          <% let radioState = []
            let index = 0;
            let state = 0;
          %>
          <%let ind = 0%> 
          <%techData.forEach((item,index) => {%>
            <tr>
                <td>
                    <input type="hidden"  name="tech[<%=ind%>][name]" value="<%= item.name%>">
                    <%= item.name%>
                </td>
                <td>
                    <input type="radio" name="tech[<%=ind%>][proficiency]" class="radio"  value="beginner" <%= item.beginner == 1 ? 'checked' : '' %>>
                    <% radioState[state++] =  item.beginner == 1 ? true : false %>
                </td>
                <td>
                    <input type="radio" name="tech[<%=ind%>][proficiency]" class="radio" value="intermediate" <%= item.intermediate == 1 ? 'checked' : '' %>>
                    <% radioState[state++] =  item.intermediate == 1 ? true : false %>

                </td>
                <td>
                    <input type="radio" name="tech[<%=ind%>][proficiency]" class="radio" value="expert" <%= item.advance == 1 ? 'checked' : '' %>>
                    <% radioState[state++] =  item.advance == 1 ? true : false %>

                </td>
                <%ind++%>
              </tr>
          <%})%>  
        </table>
        <div class="col col-12 d-flex justify-content-center m-3">
          <button type="button" id="update" class="btn btn-primary">Update</button>
          <a href="/" class="text-decoration-none btn btn-danger ms-3">Back</a>

        </div>
    </form>
  </body>
  <script>
    document.getElementById("update").addEventListener("click" , (e) => {
        document.getElementById("form").submit();
    })
    console.log(<%= radioState%>);
    let radioStateArr = [<%= radioState%>]
    document.querySelectorAll(".radio").forEach((ele,index) => {
      ele.addEventListener("click" , (e) => {
        if(!radioStateArr[index]){
          document.querySelectorAll(`.radio[name="${e.target.name}"]`).forEach((radio,radioIndex) => {
            e.target.checked = false;
          })
          radioStateArr[index] = true;
          e.target.checked = true;
        }
        else{
          document.querySelectorAll(`.radio[name="${e.target.name}"]`).forEach((radio,radioIndex) => {
            e.target.checked = false;
          })
          radioStateArr[index] = false;
          e.target.checked = false;
        }
      })
    })

  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</html>
