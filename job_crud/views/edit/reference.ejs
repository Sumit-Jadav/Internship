<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Edit Reference</title>

  <link rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"/>

  <!-- JustValidate -->
  <script src="https://unpkg.com/just-validate@latest/dist/just-validate.production.min.js"></script>
</head>

<body>

<h1 class="m-3 text-center">Edit References</h1>

<div class="container">
  <form action="/edit-reference" method="post" id="form">

    <input type="hidden" name="id" value="<%=id%>">

    <div class="d-flex justify-content-end mb-3">
      <button type="button" class="btn btn-secondary" id="r-plus">+</button>
      <button type="button" class="btn btn-primary ms-3" id="r-minus">-</button>
    </div>

    <table class="table table-bordered" id="reference-table">
      <tr>
        <th>Reference Name</th>
        <th>Reference Contact</th>
        <th>Relation</th>
      </tr>

      <% refData.forEach((ref,index) => { %>
      <tr>
        <td>
          <input type="text" name="ref_name[]" class="refname<%=index%>"
            value="<%= ref.reference_name %>">
        </td>

        <td>
          <input type="text" name="ref_contact[]" class="refcontact<%=index%>"
            value="<%= ref.reference_contact %>">
        </td>

        <td>
          <input type="text" name="ref_relation[]" class="relation<%=index%>"
            value="<%= ref.relation %>">
        </td>
      </tr>
      <% }) %>

    </table>

    <div class="text-center">
      <button type="submit" class="btn btn-primary">Update</button>
      <a href="/" class="btn btn-secondary ms-3">Home</a>
    </div>

  </form>
</div>

<script>
  const validate = new JustValidate("#form");

  let referenceTable = document.getElementById("reference-table");
  let plusBtn = document.getElementById("r-plus");
  let minusBtn = document.getElementById("r-minus");
  let rindex = <%= refData.length %>;

  // ✅ Apply validation
  function applyValidation() {

    for (let i = 0; i < rindex; i++) {

      validate.addField(`.refname${i}`, [
        { rule: "required", errorMessage: "Required" }
      ]);

      validate.addField(`.relation${i}`, [
        { rule: "required", errorMessage: "Required" }
      ]);

      validate.addField(`.refcontact${i}`, [
        { rule: "required", errorMessage: "Required" },
        {
          validator: (value) => /^[0-9]{10}$/.test(value),
          errorMessage: "Must be 10 digits"
        }
      ]);
    }
  }

  // initial validation
  applyValidation();

  // ➕ Add row
  plusBtn.addEventListener("click", () => {

    let newRow = referenceTable.insertRow();

    newRow.innerHTML = `
      <td><input type="text" name="ref_name[]" class="refname${rindex}"></td>
      <td><input type="text" name="ref_contact[]" class="refcontact${rindex}"></td>
      <td><input type="text" name="ref_relation[]" class="relation${rindex}"></td>
    `;

    rindex++;
    applyValidation(); // 🔥 important
  });

  // ➖ Remove row
  minusBtn.addEventListener("click", () => {
    if (rindex > 1) {
      referenceTable.deleteRow(-1);
      rindex--;
    }
  });

  // ✅ submit control
  validate.onSuccess((event) => {
    event.preventDefault();
    event.target.submit();
  });

</script>

</body>
</html>