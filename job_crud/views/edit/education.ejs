<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Edit Education Details</title>

  <link rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"/>

  <!-- JustValidate CDN -->
  <script src="https://unpkg.com/just-validate@latest/dist/just-validate.production.min.js"></script>
</head>

<body>
  <h1 class="text-center">Edit Education Details</h1>

  <div class="container">
    <form action="/edit-education" method="post" id="form">
      <input type="hidden" name="id" value="<%=id%>">

      <!-- Buttons -->
      <div class="col-12 d-flex justify-content-end mb-3">
        <button type="button" class="btn btn-secondary" id="e-plus">+</button>
        <button type="button" class="btn btn-primary ms-3" id="e-minus">-</button>
      </div>

      <!-- Table -->
      <table class="table table-bordered" id="education-table">
        <thead>
          <tr>
            <th>Course</th>
            <th>University</th>
            <th>Passing Year</th>
            <th>Result</th>
          </tr>
        </thead>

        <tbody>
          <% eduData.forEach(function(eduData) { %>
          <tr>
            <td>
              <select name="course[]" class="course">
                <option value="">Select</option>
                <option value="10th" <%= eduData.course === "10th" ? "selected" : "" %>>10th</option>
                <option value="12th" <%= eduData.course === "12th" ? "selected" : "" %>>12th</option>
                <option value="bachelor" <%= eduData.course === "bachelor" ? "selected" : "" %>>Bachelor's</option>
                <option value="master" <%= eduData.course === "master" ? "selected" : "" %>>Master's</option>
              </select>
            </td>

            <td>
              <input type="text" name="university[]" class="university"
                value="<%= eduData.university %>" />
            </td>

            <td>
              <input type="text" name="passing_year[]" class="passingYear"
                value="<%= eduData.passing_year %>" />
            </td>

            <td>
              <input type="text" name="result[]" class="result"
                value="<%= eduData.result %>" />
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>

      <!-- Submit -->
      <div class="text-center">
        <button type="submit" class="btn btn-success">Update</button>
        <a href="/" class="btn btn-primary ms-3">Home</a>
      </div>

    </form>
  </div>

  <script>
    const validate = new JustValidate("#form");
    const educationTable = document.getElementById("education-table").querySelector("tbody");
    const plusBtn = document.getElementById("e-plus");
    const minusBtn = document.getElementById("e-minus");

    // ✅ Apply validation to all fields
    function applyValidation() {

      document.querySelectorAll(".course").forEach((el) => {
        validate.addField(el, [
          { rule: "required", errorMessage: "Course required" }
        ]);
      });

      document.querySelectorAll(".university").forEach((el) => {
        validate.addField(el, [
          { rule: "required", errorMessage: "University required" }
        ]);
      });

      document.querySelectorAll(".passingYear").forEach((el) => {
        validate.addField(el, [
          { rule: "required", errorMessage: "Year required" },
          { rule: "integer", errorMessage: "Only numbers allowed" },
          { rule: "minLength", value: 4 },
          { rule: "maxLength", value: 4 }
        ]);
      });

      document.querySelectorAll(".result").forEach((el) => {
        validate.addField(el, [
          { rule: "required", errorMessage: "Result required" }
        ]);
      });
    }

    // Initial validation
    applyValidation();

    // ➕ Add Row
    plusBtn.addEventListener("click", function () {
      const newRow = document.createElement("tr");

      newRow.innerHTML = `
        <td>
          <select name="course[]" class="course">
            <option value="">Select</option>
            <option value="10th">10th</option>
            <option value="12th">12th</option>
            <option value="bachelor">Bachelor's</option>
            <option value="master">Master's</option>
          </select>
        </td>

        <td>
          <input type="text" name="university[]" class="university" />
        </td>

        <td>
          <input type="text" name="passing_year[]" class="passingYear" />
        </td>

        <td>
          <input type="text" name="result[]" class="result" />
        </td>
      `;

      educationTable.appendChild(newRow);

      applyValidation(); // re-bind validation
    });

    // ➖ Remove Row
    minusBtn.addEventListener("click", function () {
      const rows = educationTable.querySelectorAll("tr");
      if (rows.length > 1) {
        educationTable.removeChild(rows[rows.length - 1]);
      }
    });

    // ✅ Final submit control
    validate.onSuccess((event) => {
      event.preventDefault();
      event.target.submit();
    });

  </script>
</body>
</html>