<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Edit Preferences</title>

  <link rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"/>

  <!-- JustValidate -->
  <script src="https://unpkg.com/just-validate@latest/dist/just-validate.production.min.js"></script>
</head>

<body>

<h1 class="text-center m-3">Edit Preferences</h1>

<form action="/edit-preference" method="post" id="form">
  <input type="hidden" name="id" value="<%= id %>">

  <table class="table table-bordered">
    <tr>
      <th>Prefer Location</th>
      <th>Notice Period</th>
      <th>Expected CTC</th>
      <th>Current CTC</th>
      <th>Department</th>
    </tr>

    <% prefData.forEach((pref,index) => { %>
    <tr>

      <!-- ✅ only class added -->
      <td>
        <select name="location[]" class="location<%=index%>" multiple>
          <option value="remote" <%= data.includes("remote") ? 'selected' : '' %>>Remote</option>
          <option value="ahmedabad" <%= data.includes("ahmedabad") ? 'selected' : '' %>>Ahmedabad</option>
          <option value="bhavnagar" <%= data.includes("bhavnagar") ? 'selected' : '' %>>Bhavnagar</option>
        </select>
      </td>

      <td>
        <input type="text" name="notice" class="notice<%=index%>"
          value="<%= pref.notice_period %>">
      </td>

      <td>
        <input type="text" name="ectc" class="ectc<%=index%>"
          value="<%= pref.expected_ctc %>">
      </td>

      <td>
        <input type="text" name="cctc" class="cctc<%=index%>"
          value="<%= pref.current_ctc %>">
      </td>

      <td>
        <input type="text" name="department" class="department<%=index%>"
          value="<%= pref.department %>">
      </td>

    </tr>
    <% }) %>

  </table>

  <div class="text-center">
    <button type="submit" class="btn btn-primary">Submit</button>
    <a href="/" class="btn btn-secondary ms-3">Home</a>
  </div>
</form>

<script>
  const validate = new JustValidate("#form");

  <% prefData.forEach((pref,index) => { %>

    // ✅ Location (multi-select)
    validate.addField(".location<%=index%>", [
      {
        validator: () => {
          return document.querySelector(".location<%=index%>").selectedOptions.length > 0;
        },
        errorMessage: "Select at least one location",
      },
    ]);

    // ✅ Notice
    validate.addField(".notice<%=index%>", [
      { rule: "required", errorMessage: "Required" },
      { rule: "number", errorMessage: "Must be number" },
    ]);

    // ✅ Expected CTC
    validate.addField(".ectc<%=index%>", [
      { rule: "required", errorMessage: "Required" },
      { rule: "number", errorMessage: "Must be number" },
    ]);

    // ✅ Current CTC
    validate.addField(".cctc<%=index%>", [
      { rule: "required", errorMessage: "Required" },
      { rule: "number", errorMessage: "Must be number" },
    ]);

    // ✅ Department
    validate.addField(".department<%=index%>", [
      { rule: "required", errorMessage: "Required" },
    ]);

  <% }) %>

  validate.onSuccess((event) => {
    event.preventDefault();
    event.target.submit();
  });
</script>

</body>
</html>