<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <link rel="stylesheet" href="/css/bootstrap.css" />
  </head>
  <body class="d-flex flex-column align-items-center">
    <p class="text-danger text-center fs-3 mt-5" id="error"></p>

    <form method="post" id="get-user-form" class="w-50">
      <div class="card">
        <div class="card-header">
          <h3 class="text-center">Reset Password</h3>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="row">
              <div class="col">
                <input
                  class="form-control"
                  type="email"
                  name="email"
                  id="email"
                  placeholder="Enter your email"
                />
              </div>
            </div>
            <div class="row mt-3 d-flex justify-content-center">
              <button
                type="submit"
                id="get-user-btn"
                class="btn btn-success w-25"
              >
                Send
              </button>
            </div>
          </div>
        </div>
      </div>
    </form>
  </body>

  <script>
    let userForm = document.getElementById("get-user-form");
    let emailTxt = document.getElementById("email");
    let error = document.getElementById("error");
    userForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const formObj = Object.fromEntries(formData);

      const res = await fetch(`http://localhost:5000/users/auth/get-user`, {
        method: "post",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(formObj),
      });
      const resData = await res.json();
      if (resData.status == 404) {
        error.innerText = resData.message;
        setTimeout(() => {
          error.innerText = "";
        }, 2000);
      } else if (resData.status == 200) {
        const resObj = resData.data[0];
        window.location.href = resObj.path + "/" + resObj.userId;
      }
    });
  </script>
</html>
