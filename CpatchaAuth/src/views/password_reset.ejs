<!DOCTYPE html>
<body lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <link rel="stylesheet" href="/css/bootstrap.css" />
  </head>
  <body class="d-flex flex-column align-items-center">
    <p class="text-danger text-center fs-3 mt-5" id="error"></p>
    <p class="text-success text-center fs-3 mt-5" id="success"></p>

  <form method="post" id="update-password-form" class="w-50">
    <div class="card">
      <div class="card-header">
        <h3 class="text-center">Reset Password</h3>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="row">
            <div class="col">
              <input
                class="form-control"
                type="password"
                name="password"
                id="password"
                placeholder="Enter new Password"
              />
            </div>
          </div>
          <div class="row">
            <div class="col">
              <input
                class="form-control mt-2"
                type="password"
                name="conform_password"
                id="conform_password"
                placeholder="Re-enter new Password"
              />
            </div>
          </div>
          <input type="hidden" name="token" value="<%= token %>">
          <input type="hidden" name="id" value="<%= id %>">
          <div class="row mt-3 d-flex justify-content-center">
            <button type="submit" class="btn btn-success w-25">Update</button>
          </div>
        </div>
      </div>
    </div>
  </form>
</body>
<script>
    let resetForm = document.getElementById("update-password-form");
    let error = document.getElementById("error");
    let success = document.getElementById("success");
    let password = document.getElementById("password").value;
    let conform_password = document.getElementById("conform_password").value;
    resetForm.addEventListener("submit" , async (e) => {
        e.preventDefault();
        if(password !== conform_password){
            error.innerText = "Both Password should match"
            setTimeout(() => {
                error.innerText = ""
            }, 2000);
            return false;
        }
        const formData = new FormData(e.target);
        const formObj = Object.fromEntries(formData); 
        const res = await fetch("http://localhost:5000/users/auth/forgot/password",{
            method : "POST",
            headers : {
                "Content-Type":"application/json"
            },
            body : JSON.stringify(formObj)
        });
        const resData = await res.json();
        if(resData.status == 400 || resData.status == 404){
            error.innerText = resData.message;
            setTimeout(() => {
                error.innerText = "";
            }, 2000);
        }
        if(resData.status == 200){
            success.innerText = resData.message + " Wait for reload";
            setTimeout(() => {
                success.innerText = "";
            }, 2000);
            setTimeout(() => {
                location.href = "/users/auth/login"
            }, 3000);
        }

        
    })
</script>
</html>
