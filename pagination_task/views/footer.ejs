<script>
  const orderField = document.getElementById("orderField");
  const order = document.getElementById("order");

  // Helper function to reload page with query
  function reloadPage() {
    const fieldVal = orderField.value === "select" ? "id" : orderField.value;
    const orderVal = order.value === "select" ? "asc" : order.value;
    const page = <%= current_page %>;
    window.location.href = `/?page=${1}&orderField=${fieldVal}&order=${orderVal}`;
  }

  orderField.addEventListener("change", reloadPage);
  order.addEventListener("change", reloadPage);
</script>
